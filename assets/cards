{
  "anxious": [
    {
      "day": 1,
      "front": {
        "quote": "Courage is not the absence of fear, but action in spite of it.",
        "reflection": "Anxiety often signals that something matters to you deeply. Take a moment to breathe slowly and recognise that feeling anxious is natural. Your courage grows each time you move forward despite the fear."
      },
      "back": {
        "mantra": "I breathe in calm, I breathe out fear.",
        "reframe": "My anxiety shows me what matters. I can take one small step forward.",
        "action": "Practice 4-7-8 breathing: inhale for 4, hold for 7, exhale for 8. Repeat 3 times."
      }
    },
    {
      "day": 2,
      "front": {
        "quote": "You don't have to control your thoughts. You just have to stop letting them control you.",
        "reflection": "Anxiety loves to predict the worst. Today, notice the thought without becoming it. You are the observer — not the storm."
      },
      "back": {
        "mantra": "I am safe in this moment. Only this moment is real.",
        "reframe": "My thoughts are visitors, not residents. I choose what stays.",
        "action": "Write down the worry. Then write one reason it might not happen. Read it back slowly."
      }
    },
    {
      "day": 3,
      "front": {
        "quote": "Worry is a misuse of imagination.",
        "reflection": "Your mind is powerful. Right now it may be using that power against you. Gently redirect it — what is one thing going right today?"
      },
      "back": {
        "mantra": "I redirect my mind toward what is good and real.",
        "reframe": "My imagination is a gift. I choose to use it to build, not to fear.",
        "action": "List 3 things within arm's reach right now. Name them slowly. Feel yourself return to the room."
      }
    },
    {
      "day": 4,
      "front": {
        "quote": "Almost everything will work again if you unplug it for a few minutes — including you.",
        "reflection": "Rest is not weakness. Stepping back from the noise is one of the bravest things you can do for yourself today."
      },
      "back": {
        "mantra": "Rest is productive. I give myself permission to pause.",
        "reframe": "Slowing down is not falling behind. It is how I stay strong.",
        "action": "Set a 5-minute timer. Do nothing. No phone, no task. Just sit and breathe."
      }
    },
    {
      "day": 5,
      "front": {
        "quote": "You have survived every difficult day so far. Your track record is 100%.",
        "reflection": "Look back at what you have already come through. That resilience is not luck — it is you. You carried yourself here."
      },
      "back": {
        "mantra": "I have overcome before. I will overcome again.",
        "reframe": "My history of survival is proof of my strength.",
        "action": "Name one hard thing you have already survived. Say out loud: 'I did that. I am still here.'"
      }
    },
    {
      "day": 6,
      "front": {
        "quote": "Peace is the result of retraining your mind to process life as it is, rather than as you think it should be.",
        "reflection": "Anxiety often grows from the gap between expectation and reality. Today, soften your grip on how things 'should' look."
      },
      "back": {
        "mantra": "I release the need to control what I cannot. I trust the process.",
        "reframe": "Uncertainty is not danger. It is simply unknown — and the unknown can hold good things too.",
        "action": "Write one thing you are trying to control that is outside your power. Then write: 'I release this.'"
      }
    },
    {
      "day": 7,
      "front": {
        "quote": "You are braver than you believe, stronger than you seem, and smarter than you think.",
        "reflection": "You have shown up for seven days. That is not small. That is a choice you made for yourself — and it matters more than you know."
      },
      "back": {
        "mantra": "I am becoming the version of me who no longer fears this.",
        "reframe": "Every day I showed up was a vote for who I am choosing to become.",
        "action": "Close your eyes. Place one hand on your heart. Say: 'I am proud of you.' Mean it."
      }
    }
  ],

