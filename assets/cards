"unworthy": [
  {
    "day": 1,
    "front": {
      "quote": "You yourself, as much as anybody in the entire universe, deserve your love and affection. — Buddha",
      "reflection": "Feeling unworthy is one of the heaviest things a person can carry. But before anything else, know this — your brain generates this feeling as protection, not as truth. When life has been hard or people have been unkind, the mind learns to shrink as a way of staying safe. That shrinking is not who you are. It is what you learned. And what is learned can be gently, quietly unlearned."
    },
    "back": {
      "mantra": "I am not my worst thought about myself. I am something far greater.",
